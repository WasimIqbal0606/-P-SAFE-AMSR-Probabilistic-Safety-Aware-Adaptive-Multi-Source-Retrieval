# =====================================================
# B-P-SAFE-AMSR Research Repository
# .gitignore for journal submission with research code
# =====================================================

# ── Python bytecode and caches ──
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ── Virtual environments ──
.venv/
venv/
env/
ENV/

# ── Tool caches and coverage ──
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# ── Build and packaging artifacts ──
build/
dist/
*.egg-info/

# ── IDE and OS files ──
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# ── LaTeX intermediate files (keep .tex and .pdf) ──
*.aux
*.log
*.out
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.synctex.gz
*.toc
*.lof
*.lot
*.nav
*.snm
*.vrb

# ── Notebook checkpoints ──
.ipynb_checkpoints/

# ── Replit config (not needed for submission) ──
.replit
replit.nix

# ── Lock files (reproducibility via requirements.txt) ──
uv.lock
poetry.lock

# ── Large downloaded datasets (reproducible via scripts) ──
datasets/
data/

# ── Intermediate/legacy result directories ──
# (only results_top_tier_psafe/ is used in the paper)
results_psafe_amsr/
results_safe_amsr_v3/
results_safe_amsr_v4/
ahrc_data/
ahrc_results/
amsr_results/

# ── FAISS index caches ──
results_top_tier_psafe/cache/
*.faiss

# ── Antigravity / Gemini local state ──
.antigravityignore
.gemini/

# ── Streamlit config (legacy) ──
.streamlit/

# ── pyproject.toml (large, generated by Replit) ──
pyproject.toml
